# Copy to .env and fill in your key. Do not commit .env.
# OPENAI_API_KEY is used for provider "openai" and as fallback for "openclaw".
OPENAI_API_KEY=sk-your-key-here

# Optional: OpenClaw (uses OPENAI_API_KEY if not set)
# OPENCLAW_API_KEY=sk-your-openclaw-key

# Optional: custom OpenAI-compatible API base
# OPENAI_API_BASE=https://api.openai.com/v1
