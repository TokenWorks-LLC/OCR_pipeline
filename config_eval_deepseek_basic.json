{
  "input": {
    "input_directory": "./data/input_pdfs",
    "supported_formats": [
      ".pdf"
    ],
    "process_all_files": true,
    "specific_file": "",
    "recursive_search": false
  },
  "output": {
    "output_directory": "./data/eval_output/eval_deepseek_basic",
    "create_subdirectories": true,
    "timestamp_outputs": false
  },
  "ocr": {
    "engine": "deepseek",
    "dpi": 300,
    "languages": [
      "en"
    ],
    "enable_text_correction": false,
    "enable_reading_order": true,
    "confidence_threshold": 0.5
  },
  "deepseek": {
    "model": "deepseek-ai/DeepSeek-OCR",
    "device": "cpu",
    "prompt": "<image>\n<|grounding|>Convert the document to markdown.",
    "base_size": 1024,
    "image_size": 640,
    "crop_mode": true,
    "save_results": false,
    "test_compress": true,
    "cpu_fallback": true
  },
  "llm": {
    "enable_correction": false,
    "provider": "none",
    "model": "",
    "base_url": "",
    "timeout": 30,
    "max_concurrent_corrections": 1
  },
  "akkadian": {
    "enable_extraction": false,
    "confidence_threshold": 0.8,
    "generate_pdf_report": false,
    "translation_languages": [
      "english"
    ]
  },
  "processing": {
    "batch_size": 1,
    "max_workers": 1,
    "skip_existing": true,
    "create_visualizations": false,
    "create_html_overlay": false,
    "verbose": true,
    "deepseek_timeout": 300
  },
  "csv_output": {
    "format": "aggregated",
    "include_metadata": true,
    "include_confidence_scores": true,
    "separate_akkadian_csv": false
  },
  "evaluation": {
    "enable_benchmarking": true,
    "mode_name": "deepseek_basic",
    "output_file": "./data/eval_output/benchmark_deepseek_basic.json"
  },
  "language_detection": {
    "enable_enhanced_detection": true,
    "fallback_threshold": 0.5,
    "verbose_output": true,
    "track_metrics": true
  }
}
