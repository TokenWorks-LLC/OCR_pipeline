# AWS Configuration
AWS_REGION=us-east-1
S3_BUCKET=your-ocr-bucket-name

# Batch Queues
STANDARD_QUEUE=ocr-standard-queue
HIGH_MEMORY_QUEUE=ocr-high-memory-queue

# Escalation Thresholds
ESCALATION_CONFIDENCE=0.8
ESCALATION_MAX_PAGES=50
ESCALATION_MAX_TIME=600

# Retry Configuration
MAX_RETRIES=3

# Cost Optimization (set to 'true' to reduce resource usage)
COST_OPTIMIZATION=false

# Notifications (placeholders - update with founder approval)
DISCORD_WEBHOOK_URL=PLACEHOLDER_DISCORD_WEBHOOK
EMAIL_SMTP_SERVER=PLACEHOLDER_SMTP_SERVER
EMAIL_RECIPIENTS=ops@tokenworks.com,admin@tokenworks.com
